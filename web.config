<?xml version="1.0" encoding="utf-8"?>
<!--
  BI_BOOT_FIX_v64_WEB_CONFIG — Azure Windows Web App + iisnode config.
  Routes every HTTP request through server.js, which is the iisnode
  shim that requires dist/index.js. Includes iisnode logging so any
  startup error is captured under /home/LogFiles/iisnode/ rather than
  silently swallowed.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode"/>
    </handlers>

    <rewrite>
      <rules>
        <!-- /health and similar must hit Node, not be served as static. -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode runtime settings -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot; --max-old-space-size=512"
      watchedFiles="web.config;*.js;dist\*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
    />

    <!-- Show iisnode logs when something goes wrong -->
    <httpErrors existingResponse="PassThrough" />

    <!-- Don't expose iisnode log directory to the public -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="iisnode" />
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
