NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bi_server
JWT_SECRET=dev-jwt-secret
JWT_REFRESH_SECRET=dev-refresh-secret

# BI staff auth
BI_STAFF_JWT_SECRET=dev-bi-staff-secret

# PGI integration
PGI_API_KEY=test_pgi_api_key
PGI_WEBHOOK_SECRET=test_pgi_webhook_secret
PGI_BASE_URL=https://api.pgicover.com/api/v2/
USE_PGI_STUB=true

# External integrations (safe local defaults)
SENDGRID_API_KEY=
SENDGRID_FROM=hello@borealinsurance.ca
TWILIO_ACCOUNT_SID=test_twilio_sid
TWILIO_AUTH_TOKEN=test_twilio_token
TWILIO_FROM=+10000000000
TWILIO_VERIFY_SERVICE_SID=test_verify_service_sid
ALERT_SMS_TO=+10000000000

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
PURGE_BUFFER_DAYS=30
OPENAI_API_KEY=
